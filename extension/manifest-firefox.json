{
  "manifest_version": 3,
  "name": "Loggy",
  "version": "1.1.4",
  "description": "Capture and export Console & Network logs for LLM debugging",
  "devtools_page": "devtools.html",
  "background": {
    "scripts": [
      "background/index.js"
    ],
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "platform_info"
  ],
  "host_permissions": [
    "http://localhost:*/",
    "*://*/*"
  ],
  "content_security_policy": {
    "extension_pages": "default-src 'self'; style-src 'self' 'unsafe-inline'; object-src 'none'; base-uri 'none'; img-src 'self' data:; connect-src *;"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "loggy@devtools-extension",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  }
}
