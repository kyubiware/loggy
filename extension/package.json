{
  "name": "loggy",
  "version": "1.0.2",
  "description": "",
  "main": "devtools.mjs",
  "scripts": {
    "prepare": "husky",
    "build": "npm run build:chrome && npm run package:firefox",
    "dev": "vite --mode chrome",
    "build:chrome": "vite build --mode chrome",
    "build:firefox": "vite build --mode firefox",
    "package:firefox": "npm run build:firefox && rm -f loggy-firefox.xpi && (cd dist-firefox && zip -r ../loggy-firefox.xpi .)",
    "build:vite": "vite build",
    "build:ts": "tsc",
    "build:copy": "cp manifest.json icons/*.png dist/ && cp devtools.html dist/ && cp devtools.mjs dist/",
    "postbuild:chrome": "cp manifest-chrome.json dist-chrome/manifest.json && mkdir -p dist-chrome/icons && cp icons/*.png dist-chrome/icons/",
    "postbuild:firefox": "cp manifest-firefox.json dist-firefox/manifest.json && mkdir -p dist-firefox/icons && cp icons/*.png dist-firefox/icons/ && node scripts/rewrite-firefox-manifest.cjs && node scripts/sanitize-firefox-bundle.cjs && node scripts/fix-content-scripts.cjs",
    "clean": "rm -rf dist dist-*",
    "prebuild": "npm run clean",
    "prebuild:chrome": "rm -rf dist dist-chrome",
    "prebuild:firefox": "rm -rf dist dist-firefox",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "typecheck": "npx tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "source-zip": "node scripts/prepare-source-zip.cjs",
    "sign:firefox": "dotenv -- web-ext sign --source-dir dist-firefox --channel unlisted",
    "lint:firefox": "web-ext lint --source-dir dist-firefox",
    "release": "node scripts/release.cjs"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "module",
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@crxjs/vite-plugin": "^2.4.0",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "^0.1.36",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/ui": "^4.0.18",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.2.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "vitest-chrome": "^0.1.0"
  },
  "dependencies": {
    "@radix-ui/react-tooltip": "^1.2.8",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1"
  }
}
