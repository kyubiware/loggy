{
  "name": "loggy",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "workspaces": ["extension", "serve"],
  "scripts": {
    "build": "npm run build --workspace=extension",
    "test": "npm run test --workspace=extension && npm run test --workspace=serve",
    "lint": "npm run lint --workspace=extension",
    "ci": "npm run typecheck --workspace=extension && npm run lint --workspace=extension && npm run test:run --workspace=extension && npm run typecheck --workspace=serve && npm run test --workspace=serve",
    "firefox": "firefox-devedition --remote-debugging-port 6000",
    "firefox:dev": "npm run install:firefox && npm run firefox",
    "firefox:debug": "npm run install:firefox:debug && npm run firefox",
    "install:firefox": "npm run install:firefox --workspace=extension",
    "install:firefox:debug": "LOGGY_DEBUG_BUILD=true npm run install:firefox --workspace=extension",
    "publish:serve": "npm publish --workspace=serve --access public",
    "release:extension:patch": "bash scripts/release-extension.sh patch",
    "release:extension:minor": "bash scripts/release-extension.sh minor",
    "release:extension:major": "bash scripts/release-extension.sh major",
    "release:serve:patch": "bash scripts/release-serve.sh patch",
    "release:serve:minor": "bash scripts/release-serve.sh minor",
    "release:serve:major": "bash scripts/release-serve.sh major",
    "package:chrome": "npm run package:chrome --workspace=extension"
  },
  "devDependencies": {
  }
}
