{
  "name": "loggy-serve",
  "version": "1.4.0",
  "description": "Fastify companion server for Loggy markdown exports",
  "type": "module",
  "author": "kyubiware",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kyubiware/loggy.git",
    "directory": "serve"
  },
  "bin": {
    "loggy": "dist/cli.js"
  },
  "files": [
    "dist/"
  ],
  "exports": {
    ".": {
      "import": "./dist/server.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "start": "node dist/cli.js",
    "dev": "tsx --watch src/cli.ts",
    "curl:post": "curl -s -w '\\nHTTP %{http_code}' -X POST http://127.0.0.1:8743/loggy -H 'Content-Type: text/plain' -d 'Hello Loggy!'",
    "curl:export": "curl -s -w '\\nHTTP %{http_code}' http://127.0.0.1:8743/loggy/export",
    "curl:handshake": "curl -s -w '\\nHTTP %{http_code}' http://127.0.0.1:8743/loggy/handshake",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "clipboardy": "^5.3.1",
    "fastify": "^5.6.1",
    "update-notifier": "^7.3.1"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/update-notifier": "^6.0.8",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
